{
  "name": "movietheatre-backend",
  "version": "1.0.0",
  "description": "Express + MongoDB backend for MovieTheatre",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "predev": "node scripts/kill-port.js",
    "dev": "nodemon --watch . --ext js,json --ignore .env --ignore .env.* --ignore node_modules --delay 1500ms server.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.1",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
